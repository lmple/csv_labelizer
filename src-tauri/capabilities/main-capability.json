{
  "$schema": "https://tauri.app/schema/capabilities.json",
  "identifier": "main-capability",
  "description": "Permissions for CSV Labelizer main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-read",
    "fs:allow-write",
    "fs:read-all",
    "fs:write-all"
  ]
}
